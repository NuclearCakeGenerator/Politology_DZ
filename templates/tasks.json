{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Собрать реферат в Docker (Latexmk)",
            "type": "shell",
            "command": "docker",
            "args": [
                "run",
                "--rm",
                "-v",
                "${workspaceFolder}:/data",
                "texlive/texlive:latest", // Поменяли образ на официальный
                "latexmk",
                "-pdf",
                "-interaction=nonstopmode",
                "-synctex=1",
                "-cd",
                "/data/main.tex"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        }
    ]
}